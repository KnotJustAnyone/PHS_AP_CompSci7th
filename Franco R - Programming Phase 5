import datetime

categories = ["Utilities", "Groceries", "Shopping", "Food", "Transportation"]

while True:
    print("\n1. Add Transaction")
    print("2. View All Transactions")
    print("3. View Transactions by Category")
    print("4. Exit")

    choice = input("Choose an option: ")

    if choice == "1":
        name = input("Enter transaction name: ")
        amount = input("Enter amount: ")

        print("\nChoose a category:")
        for i in range(len(categories)):
            print(f"{i + 1}. {categories[i]}")

        cat_choice = int(input("Enter category number: "))
        
        if 1 <= cat_choice <= len(categories):
            category = categories[cat_choice - 1]
        else:
            print("Invalid category. Defaulting to 'Other'.")
            category = "Other"

        date_time = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        with open("transactions.txt", "a") as file:
            file.write(f"{date_time} | {name} - ${amount} - {category}\n")

        print("Transaction saved.")

    elif choice == "2":
        print("\nTransactions:")

        total = 0
        category_totals = {}

        try:
            with open("transactions.txt", "r") as file:
                for line in file:
                    print(line.strip())

                    parts = line.strip().split(" - $")
                    if len(parts) > 1:
                        amount_part = parts[1].split(" - ")[0]
                        category_part = parts[1].split(" - ")[1]

                        amount_value = float(amount_part)

                        total += amount_value

                        if category_part in category_totals:
                            category_totals[category_part] += amount_value
                        else:
                            category_totals[category_part] = amount_value

                print(f"\nTotal Spent: ${total}")

                print("\nCategory Totals:")
                for category in category_totals:
                    print(f"{category}: ${category_totals[category]}")

        except:
            print("No transactions yet.")

    elif choice == "3":
        print("\nChoose a category to view:")
        for i in range(len(categories)):
            print(f"{i + 1}. {categories[i]}")

        cat_choice = int(input("Enter category number: "))

        if 1 <= cat_choice <= len(categories):
            selected_category = categories[cat_choice - 1]
            print(f"\nTransactions for {selected_category}:")

            category_total = 0

            try:
                with open("transactions.txt", "r") as file:
                    found = False
                    for line in file:
                        if selected_category in line:
                            print(line.strip())
                            found = True

                            parts = line.strip().split(" - $")
                            amount_part = parts[1].split(" - ")[0]
                            category_total += float(amount_part)

                    if found:
                        print(f"\nTotal for {selected_category}: ${category_total}")
                    else:
                        print("No transactions in this category.")

            except:
                print("No transactions yet.")
        else:
            print("Invalid category.")

    elif choice == "4":
        print("Goodbye!")
        break

    else:
        print("Invalid choice.")
